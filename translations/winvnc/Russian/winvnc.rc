/////////////////////////////////////////////////////////////////////////////
//
// String Table
//

STRINGTABLE
BEGIN
    IDI_WINVNC              "UltraVNC Server"
END

STRINGTABLE
BEGIN
    IDS_WARNING             "ВНИМАНИЕ: по умолчанию этот сеанс не использует шифрование. Не отправляйте конфиденциальные данные, если не уверены, что соединение защищено.\n\n"
END

STRINGTABLE
BEGIN
    ID_CURRENT_USER_PROP    "UltraVNC Server: свойства текущего пользователя"
    ID_DEFAULT_SYST_PROP    "UltraVNC Server: свойства локальной системы по умолчанию"
    ID_DESKTOP_BITBLT_MEM   "vncDesktop: устройство памяти не поддерживает GetDIBits\nUltraVNC Server нельзя использовать с этим графическим драйвером"
    ID_DESKTOP_BITBLT_ROOT  "vncDesktop: корневое устройство не поддерживает BitBlt\nUltraVNC Server нельзя использовать с этим графическим драйвером"
    ID_DESKTOP_PLANAR_NOTC  "vncDesktop: текущий дисплей PLANAR, не CHUNKY!\nUltraVNC Server нельзя использовать с этим графическим драйвером"
    ID_FAILED_CONNECT_LISTING_VIEW "Не удалось подключиться к ожидающему VNC Viewer"
    ID_FAILED_INIT          "Не удалось инициализировать систему сокетов"
    ID_MB1                  "MB1"
    ID_NO_CURRENT_USER_ERR  "Настройки UltraVNC Server для текущего пользователя сейчас недоступны."
    ID_NO_EXIST_INST        "Не удалось связаться с существующим экземпляром UltraVNC Server"
END

STRINGTABLE
BEGIN
    ID_WARNING              "ВНИМАНИЕ"
    ID_WINVNC_ERROR         "UltraVNC Server — ошибка"
    ID_WINVNC_USAGE         "Использование UltraVNC Server"
    ID_WINVNC_WARNIN        "UltraVNC Server — предупреждение"
    ID_WVNC                 "WVNC"
    IDS_WINDOWS_XP_SPECIAL_BUILD "Для Windows XP нужна специальная сборка"
END

STRINGTABLE
BEGIN
    ID_ANOTHER_INST         "Другой экземпляр UltraVNC Server уже запущен"
    ID_AUTHAD_NOT_FO        "Вы выбрали MS-Logon, но authad.dll\nне найден. Проверьте установку"
    ID_AUTH_NOT_FO          "Вы выбрали MS-Logon, но auth.dll\nне найден. Проверьте установку"
    ID_AUTOACCEPT_U         "Автоприём: %u"
    ID_AUTOREJECT_U         "Автоотказ: %u"
    ID_CADERROR             "Ctrl-Alt-Del требует службу; нет разрешения"
    ID_CADERRORFILE         "Файл cad.exe не найден в папке UltraVNC Server winvnc.exe"
