/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_TRAYMENU MENU
BEGIN
    POPUP "tray"
    BEGIN
        MENUITEM "&Настройки",                   ID_ADMIN_PROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "&О UltraVNC Server...",   ID_ABOUT
        POPUP "Наши ссылки"
        BEGIN
            MENUITEM "Сайт",                    ID_VISITUSONLINE_HOMEPAGE
            MENUITEM "Форум",                       ID_VISITUSONLINE_FORUM
            MENUITEM "GitHub",                      ID_VISITUSONLINE_GITHUB
            MENUITEM "Mastodon",                    ID_VISITUSONLINE_MASTODON
            MENUITEM "Bluesky",                     ID_VISITUSONLINE_BLUESKY
            MENUITEM "Facebook",                    ID_VISITUSONLINE_FACEBOOK
            MENUITEM "X/Twitter",                   ID_VISITUSONLINE_XTWITTER
            MENUITEM "Reddit",                      ID_VISITUSONLINE_REDDIT
            MENUITEM "OpenHub",                     ID_VISITUSONLINE_OPENHUB
        END
        MENUITEM SEPARATOR
        MENUITEM "Добавить &клиента",             ID_OUTGOING_CONN
        MENUITEM "Отключить &всех",           ID_KILLCLIENTS
        MENUITEM SEPARATOR
        MENUITEM "Список &клиентов",           ID_LISTCLIENTS
        MENUITEM SEPARATOR
        MENUITEM "Установить службу",             ID_RUNASSERVICE
        MENUITEM "Удалить службу",           ID_UNINSTALL_SERVICE
        MENUITEM "Остановить службу",                ID_CLOSE_SERVICE
        MENUITEM "Запустить службу (сначала установите)", ID_START_SERVICE
        MENUITEM "Перезагрузка в безоп. режим",         ID_REBOOTSAFEMODE
        MENUITEM "Принуд. перезагрузка",       ID_REBOOT_FORCE
        MENUITEM SEPARATOR
        MENUITEM "&Закрыть VNC-соединения",      ID_CLOSE
    END
END

IDR_TRAYMENU1 MENU
BEGIN
    POPUP "tray"
    BEGIN
        MENUITEM "&О UltraVNC Server...",   ID_ABOUT
        MENUITEM SEPARATOR
        MENUITEM "&Закрыть VNC-соединения",      ID_CLOSE
    END
END


